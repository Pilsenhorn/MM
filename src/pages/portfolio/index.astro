---
import Layout from "../../layouts/Layout.astro";
import { portfolio } from "../../data/portfolio";
import PortfolioCard from "../../sections/PortfolioCard.astro";
import Header from "../../sections/Header.astro";
---

<Layout>
<Header variant="portfolio"/>

<section class="px-4 py-28 sm:px-6 md:py-36">
  <div class="mx-auto max-w-7xl space-y-14">

    <div class="max-w-3xl space-y-5">
      <span class="inline-flex w-fit rounded-full border border-(--muted) px-4 py-1.5 text-sm">
        Směry designu
      </span>

      <h1 class="tracking-heading text-4xl font-bold leading-tight sm:text-5xl">
        Ukázky přemýšlení o značce a webu
      </h1>

      <p class="max-w-2xl text-lg leading-relaxed text-(--text-secondary)">
        Některé ukázky vznikly jako explorace design směru.
        Nejde o reference klientů, ale o způsob, jak přemýšlím o značce,
        důvěře a rozhodování klienta.
      </p>
    </div>

    <div class="grid gap-14 md:grid-cols-2">
      {portfolio.map((project) => (
        <PortfolioCard project={project} />
      ))}
    </div>

  </div>
</section>

</Layout>