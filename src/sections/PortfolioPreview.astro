---
import { portfolio } from "../data/portfolio";

const featuredProjects = portfolio.slice(0, 3);
---

<section id="portfolio-preview" class="px-4 py-28 sm:px-6">
  <div class="mx-auto max-w-7xl">

    <div class="max-w-3xl space-y-5">
      <span class="inline-flex w-fit rounded-full border border-(--muted) px-4 py-1.5 text-sm">
        Portfolio
      </span>

      <h2 class="tracking-heading text-4xl font-bold leading-tight sm:text-5xl">
        Ukázky design směrů 
      </h2>

      <p class="max-w-2xl text-lg leading-relaxed">
        Každý projekt vzniká individuálně podle značky, oboru a cílového klienta.
        Od prvního konceptu až po finální podobu webu.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">

      {featuredProjects.map((project) => (
        <a
          href="/portfolio"
          class="group block overflow-hidden rounded-4xl border border-(--muted)/30 transition hover:border-(--accent)/40"
        >

          <div class="relative aspect-4/5 overflow-hidden">

            <img
              src={project.moodboard}
              alt={project.title}
              class="absolute inset-0 h-full w-full object-cover transition-opacity duration-500 group-hover:opacity-0"
              loading="lazy"
            />

            <img
              src={project.mockup}
              alt={project.title}
              class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100"
              loading="lazy"
            />

          </div>

          <div class="space-y-2 p-5">

            <p class="text-sm text-(--muted)">
              {project.category}
            </p>

            <h3 class="tracking-heading text-xl font-semibold">
              {project.title}
            </h3>

          </div>

        </a>
      ))}

    </div>

    <div class="mt-10 flex justify-center">
      <a
        href="/portfolio"
        class="tracking-cta inline-flex rounded-full bg-(--accent) px-6 py-3 text-(--background) transition hover:bg-(--accent-hover)"
      >
        Zobrazit celé portfolio
      </a>
    </div>

  </div>
</section>