<header class="sticky top-0 left-0 z-50 w-full px-3 pt-3 sm:px-4">
  <div class="mx-auto w-full">
    <div class="flex w-full items-center justify-between rounded-3xl border border-(--text-primary)/15 bg-(--background)/80 px-3 py-3 backdrop-blur-md sm:px-5">
      <a href="/" class="flex shrink-0 items-center">
        <img
          src="/logo-80.png"
          alt="Michal Mikulenka"
          width="40"
          height="40"
          decoding="async"
          fetchpriority="high"
          class="h-9 w-9 sm:h-10 sm:w-10"
        />
      </a>

      <nav class="hidden items-center gap-5 text-sm font-medium lg:flex xl:gap-8 xl:text-base">
        <a
          href="https://calendly.com/pilsenhorn/audit-systemu-30-min"
          target="_blank"
          class="tracking-cta rounded-full bg-(--accent) px-5 py-2.5 text-(--background) transition hover:bg-(--accent-hover)"
        >
          Zjistit, kde ztrácím klienty
        </a>
        <a href="#problem" class="transition hover:text-(--accent)">Problém</a>
        <a href="#solution" class="transition hover:text-(--accent)">Řešení</a>
        <a href="#case" class="transition hover:text-(--accent)">Jak pracuji</a>
        <a href="#offer" class="transition hover:text-(--accent)">Nabídka</a>
      </nav>

      <button
        id="menu-btn"
        class="flex shrink-0 flex-col gap-1 rounded-xl p-2 lg:hidden"
        aria-label="Otevřít navigaci"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="h-0.5 w-6 bg-(--text-primary)"></span>
        <span class="h-0.5 w-6 bg-(--text-primary)"></span>
        <span class="h-0.5 w-6 bg-(--text-primary)"></span>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed left-3 right-3 top-20 hidden flex-col gap-2 overflow-y-auto rounded-3xl border border-(--text-primary)/15 bg-(--background)/95 p-3 shadow-xl backdrop-blur-md sm:left-4 sm:right-4 lg:hidden"
  >
    <a
      href="https://calendly.com/pilsenhorn/audit-systemu-30-min"
      target="_blank"
      class="tracking-cta rounded-2xl bg-(--accent) px-4 py-3 text-center leading-snug text-(--background) transition hover:bg-(--accent-hover)"
    >
      Zjistit, kde ztrácím klienty
    </a>
    <a href="#problem" class="rounded-2xl px-4 py-3 text-center text-base transition hover:bg-white/40">Problém</a>
    <a href="#solution" class="rounded-2xl px-4 py-3 text-center text-base transition hover:bg-white/40">Řešení</a>
    <a href="#case" class="rounded-2xl px-4 py-3 text-center text-base transition hover:bg-white/40">Jak pracuji</a>
    <a href="#offer" class="rounded-2xl px-4 py-3 text-center text-base transition hover:bg-white/40">Nabídka</a>
  </div>
</header>
